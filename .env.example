# Copy this file to .env locally.
# Never commit .env.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AWS_PROFILE=
AWS_REGION=us-east-1
AWS_BEARER_TOKEN_BEDROCK=
GOOGLE_API_KEY=
XIAOMI_MIMO_API_KEY=
XIAOMI_MIMO_MODEL=mimo-v2-omni
XIAOMI_MIMO_OPENAI_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
XIAOMI_MIMO_ANTHROPIC_BASE_URL=https://token-plan-sgp.xiaomimimo.com/anthropic
NVIDIA_API_KEY_A=
NVIDIA_API_KEY_B=

# Optional local path to the previous project.
LEGACY_STREAMING_PROJECT_PATH=/Users/guanjie/Documents/llm_api/streaming_or_not/streaming-vs-nonstreaming

# External safety prompt source for Phase 3.
# Keep raw unsafe prompts outside this repository.
LSSA_SAFETY_PROMPT_ROOT=/Users/guanjie/Documents/llm_api/streaming_or_not/streaming-vs-nonstreaming/data/safety

# Optional LLM-as-a-judge configuration. Keep judge calls disabled by default.
LSSA_JUDGE_PROVIDER=nvidia_nim
LSSA_JUDGE_BASE_URL=https://integrate.api.nvidia.com/v1
LSSA_JUDGE_A_API_KEY_ENV=NVIDIA_API_KEY_A
LSSA_JUDGE_A_MODEL=nvidia/llama-3.1-nemotron-safety-guard-8b-v3
LSSA_JUDGE_B_API_KEY_ENV=NVIDIA_API_KEY_B
LSSA_JUDGE_B_MODEL=meta/llama-guard-4-12b
